{
  "name": "smkc-score-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "node scripts/check-format-changed.mjs",
    "test": "SKIP_OPENNEXT_CLOUDFLARE_DEV=1 NODE_ENV=test NODE_OPTIONS='--max-old-space-size=4096' jest",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "e2e:install-browser": "node e2e/install-browser.js",
    "e2e:all": "node e2e/tc-all.js",
    "e2e:archive": "node e2e/tc-archive.js",
    "e2e:cleanup": "node e2e/cleanup.js",
    "e2e:launch-smoke": "node e2e/browser-launch-smoke.js",
    "e2e:bm": "node e2e/tc-bm.js",
    "e2e:debug-fill": "node e2e/tc-debug-fill.js",
    "e2e:mr": "node e2e/tc-mr.js",
    "e2e:gp": "node e2e/tc-gp.js",
    "e2e:ta": "node e2e/tc-ta.js",
    "e2e:ta-flow": "node e2e/tc-ta-flow.js",
    "e2e:preview": "node e2e/run-preview.js tc-all.js",
    "e2e:preview:all": "npm run e2e:preview --",
    "e2e:preview:login": "node e2e/login-preview-admin.js",
    "e2e:preview:cleanup": "node e2e/run-preview.js cleanup.js",
    "e2e:preview:launch-smoke": "node e2e/run-preview.js browser-launch-smoke.js",
    "e2e:preview:archive": "node e2e/run-preview.js tc-archive.js",
    "e2e:preview:bm": "node e2e/run-preview.js tc-bm.js",
    "e2e:preview:debug-fill": "node e2e/run-preview.js tc-debug-fill.js",
    "e2e:preview:mr": "node e2e/run-preview.js tc-mr.js",
    "e2e:preview:gp": "node e2e/run-preview.js tc-gp.js",
    "e2e:preview:ta": "node e2e/run-preview.js tc-ta.js",
    "e2e:preview:ta-flow": "node e2e/run-preview.js tc-ta-flow.js",
    "e2e:preview:overlay": "node e2e/run-preview.js tc-overlay.js",
    "finals:prepare": "node scripts/create-finals-ready-tournament.js",
    "finals:reapply-ranks": "node scripts/reapply-rank-overrides.js",
    "postinstall": "node scripts/prisma-generate.js",
    "prebuild:cf": "PRISMA_SCHEMA_ENGINE_BINARY=/dev/null PRISMA_QUERY_ENGINE_LIBRARY=/dev/null PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma generate",
    "build:cf": "opennextjs-cloudflare build",
    "db:migrations:list": "wrangler d1 migrations list DB --remote",
    "db:migrations:apply": "wrangler d1 migrations apply DB --remote",
    "db:migrations:list:preview": "wrangler d1 migrations list DB --remote --env preview",
    "db:migrations:apply:preview": "wrangler d1 migrations apply DB --remote --env preview",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "preview:fast": "opennextjs-cloudflare dev",
    "deploy:cf": "npm run db:migrations:apply && wrangler deploy",
    "deploy:cf:preview": "npm run db:migrations:apply:preview && wrangler deploy --env preview",
    "deploy": "npm run build:cf && npm run deploy:cf",
    "deploy:preview": "npm run build:cf && npm run deploy:cf:preview",
    "e2e:ta-br": "node e2e/tc-ta-battle-royale.js",
    "e2e:preview:ta-br": "node e2e/run-preview.js tc-ta-battle-royale.js"
  },
